{
  "projectId": "5bfe5295-0a63-4ddb-aed7-023026b35080",
  "shape": "package",
  "pkg": "progra",
  "globalName": "Progra",
  "entry": "./.design-sync/entry.ts",
  "srcDir": "components",
  "tsconfig": "tsconfig.json",
  "buildCmd": "./.ds-sync/node_modules/.bin/tailwindcss -i app/globals.css -o .design-sync/.cache/tailwind-compiled.css",
  "cssEntry": ".design-sync/.cache/tailwind-compiled.css",
  "tokensPkg": "progra",
  "tokensGlob": ".design-sync/fonts.css",
  "runtimeFontPrefixes": ["Hanken Grotesk", "Newsreader"],
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "520x480" },
    "AlertDialog": { "cardMode": "single", "viewport": "520x420" },
    "Toaster": { "cardMode": "single", "viewport": "420x300" },
    "BottomNav": { "cardMode": "single", "viewport": "420x180" }
  },
  "componentSrcMap": {
    "Button": "components/ui/button.tsx",
    "Card": "components/ui/card.tsx",
    "Input": "components/ui/input.tsx",
    "Label": "components/ui/label.tsx",
    "Tabs": "components/ui/tabs.tsx",
    "Toaster": "components/ui/sonner.tsx",
    "Checkbox": "components/ui/checkbox.tsx",
    "Separator": "components/ui/separator.tsx",
    "Dialog": "components/ui/dialog.tsx",
    "AlertDialog": "components/ui/alert-dialog.tsx",
    "Badge": "components/ui/badge.tsx",
    "Textarea": "components/ui/textarea.tsx",
    "WeekStrip": "components/week-strip.tsx",
    "PageSkeleton": "components/page-skeleton.tsx",
    "GoalProgressBar": "components/goal-progress.tsx",
    "CategoryPicker": "components/category-picker.tsx",
    "CategoryMarker": "components/category-marker.tsx",
    "WeekBreakdown": "components/week-breakdown.tsx",
    "ColorSwatches": "components/color-swatches.tsx",
    "BottomNav": "components/bottom-nav.tsx",
    "WeeklyHabits": null,
    "RecapCard": null,
    "GoalPicker": null,
    "HomeActions": null,
    "SessionDialog": null,
    "CategorizationReviewDialog": null,
    "CategorizeEventsButton": null,
    "CategorizePeriodButton": null,
    "EventCategoryDialog": null,
    "SyncCalendarButton": null,
    "EnsureProfileSync": null
  }
}
